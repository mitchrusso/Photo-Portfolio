generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  OWNER
  ADMIN
  EDITOR
  CLIENT
}

enum SystemRole {
  USER
  SUPPORT
  SUPERADMIN
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  UNPAID
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum OveragePolicy {
  ASK_FIRST
  AUTO_UPGRADE_NEXT_TIER
  AUTO_BUY_BLOCKS
}

enum GalleryPrivacy {
  PUBLIC
  UNLISTED
  PASSWORD
  CLIENT_PORTAL
  PRIVATE
}

enum GalleryStatus {
  DRAFT
  PROOFING
  FOR_SALE
  DELIVERED
  ARCHIVED
}

enum PhotoKind {
  IMAGE
  RAW
  VIDEO
}

enum WatermarkMode {
  TEXT
  IMAGE
  BOTH
}

enum WatermarkPosition {
  TOP_LEFT
  TOP_RIGHT
  CENTER
  BOTTOM_LEFT
  BOTTOM_RIGHT
}

enum ContentType {
  PAGE
  BLOG
  TRIP
  ARTICLE
  GEAR
}

enum ContentStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum StorageEventType {
  ORIGINAL_UPLOADED
  DISPLAY_GENERATED
  THUMBNAIL_GENERATED
  WATERMARK_UPLOADED
  FILE_DELETED
  IMPORTED
  ADJUSTMENT
}

enum StorageDeletionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  name                 String?
  firstName            String?
  lastName             String?
  phone                String?
  image                String?
  authProviderId       String?               @unique
  systemRole           SystemRole            @default(USER)
  adminPermissions     Json?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  memberships          WorkspaceMember[]
  contactMessages      ContactMessage[]
  trialSignups         TrialSignup[]
  magicLoginTokens     MagicLoginToken[]
  adminAuditLogs       AdminAuditLog[]
  crmGoogleConnections CrmGoogleConnection[]
  crmTasks             CrmTask[]
  crmMeetings          CrmMeeting[]
  crmNotes             CrmNote[]
  crmOutreach          CrmOutreach[]
}

model MagicLoginToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([expiresAt])
}

model RequestRateLimit {
  keyHash     String
  windowStart DateTime
  count       Int      @default(1)
  expiresAt   DateTime

  @@id([keyHash, windowStart])
  @@index([expiresAt])
}

model StripeWebhookEvent {
  id          String    @id
  eventType   String
  livemode    Boolean   @default(false)
  status      String    @default("PROCESSING")
  attempts    Int       @default(1)
  lastError   String?
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([createdAt])
}

model Workspace {
  id                  String               @id @default(cuid())
  name                String
  slug                String               @unique
  welcomeTourPending  Boolean              @default(false)
  ownerName           String?
  publicBrandName     String?
  publicDomain        String?
  websiteSubdomain    String?              @unique
  supportEmail        String?
  storageUsedBytes    BigInt               @default(0)
  storageLimitBytes   BigInt               @default(2147483648)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  members             WorkspaceMember[]
  subscription        Subscription?
  galleries           Gallery[]
  portfolioGroups     PortfolioGroup[]
  clients             Client[]
  content             ContentPost[]
  gearItems           GearItem[]
  storageEvents       StorageUsageEvent[]
  storageDeletionJobs StorageDeletionJob[]
  contactMessages     ContactMessage[]
  socialShareEvents   SocialShareEvent[]
  trialSignups        TrialSignup[]
  cancellationSurveys CancellationSurvey[]
  operationalEvents   OperationalEvent[]
  socialConnections   SocialConnection[]
  socialDeliveries    SocialDelivery[]
  importCredential    ImportCredential?
}

model ImportCredential {
  id          String    @id @default(cuid())
  workspaceId String    @unique
  tokenHash   String    @unique
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model PortfolioGroup {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  position    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
  @@index([workspaceId, position])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(EDITOR)
  createdAt   DateTime      @default(now())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Plan {
  id                String         @id @default(cuid())
  name              String
  slug              String         @unique
  stripePriceId     String?        @unique
  monthlyPriceCents Int
  annualPriceCents  Int?
  storageLimitBytes BigInt
  trialDays         Int            @default(14)
  galleryLimit      Int?
  memberLimit       Int?
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  subscriptions     Subscription[]
}

model Subscription {
  id                      String               @id @default(cuid())
  workspaceId             String               @unique
  planId                  String
  status                  SubscriptionStatus   @default(TRIALING)
  billingCycle            BillingCycle?
  stripeCustomerId        String?              @unique
  stripeSubscriptionId    String?              @unique
  stripeCheckoutSessionId String?              @unique
  stripePriceId           String?
  trialStartedAt          DateTime?
  trialEndsAt             DateTime?
  currentPeriodStart      DateTime?
  currentPeriodEnd        DateTime?
  cancelAtPeriodEnd       Boolean              @default(false)
  storagePurchasedBytes   BigInt               @default(0)
  autoRolloverEnabled     Boolean              @default(false)
  overagePolicy           OveragePolicy        @default(ASK_FIRST)
  storageAlertLevel       Int                  @default(0)
  storageWarningSentAt    DateTime?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  workspace               Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan                    Plan                 @relation(fields: [planId], references: [id])
  cancellationSurveys     CancellationSurvey[]
}

model CancellationSurvey {
  id             String        @id @default(cuid())
  subscriptionId String?
  workspaceId    String?
  email          String
  reason         String
  notes          String?
  source         String        @default("CANCEL_SURVEY")
  createdAt      DateTime      @default(now())
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  workspace      Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([subscriptionId])
  @@index([workspaceId])
  @@index([email])
  @@index([createdAt])
}

model EmailAutomationDelivery {
  id             String    @id @default(cuid())
  deliveryKey    String    @unique
  subscriptionId String?
  workspaceId    String?
  email          String
  automationKey  String
  event          String
  status         String    @default("PENDING")
  providerStatus String?
  metadata       Json?
  sentAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([subscriptionId])
  @@index([workspaceId])
  @@index([email])
  @@index([automationKey])
  @@index([event])
  @@index([sentAt])
}

model TrialSignup {
  id                          String             @id @default(cuid())
  acceptableUseAcceptedAt     DateTime?
  acceptableUseVersion        String?
  email                       String
  firstName                   String
  lastName                    String
  phone                       String?
  studioName                  String?
  website                     String?
  planSlug                    String
  billingCycle                BillingCycle?
  storageRequested            String?
  subscriberLicenseAcceptedAt DateTime?
  subscriberLicenseSignerName String?
  subscriberLicenseVersion    String?
  marketingConsent            Boolean            @default(false)
  stripeCustomerId            String?
  stripeCheckoutSessionId     String?
  couponCodeId                String?
  oneTimeAccessCodeId         String?            @unique
  startupSequenceEnabled      Boolean            @default(true)
  autoresponderStatus         String             @default("PENDING")
  trialStartedAt              DateTime           @default(now())
  trialEndsAt                 DateTime
  termsAcceptedAt             DateTime?
  termsVersion                String?
  createdAt                   DateTime           @default(now())
  userId                      String?
  workspaceId                 String?
  user                        User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  workspace                   Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  couponCode                  CouponCode?        @relation(fields: [couponCodeId], references: [id], onDelete: SetNull)
  oneTimeAccessCode           OneTimeAccessCode? @relation(fields: [oneTimeAccessCodeId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([planSlug])
  @@index([trialEndsAt])
  @@index([couponCodeId])
  @@index([oneTimeAccessCodeId])
}

model Client {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  email       String?
  phone       String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  galleries   Gallery[]

  @@index([workspaceId, email])
}

model Gallery {
  id                 String             @id @default(cuid())
  workspaceId        String
  clientId           String?
  slug               String
  name               String
  description        String?
  status             GalleryStatus      @default(DRAFT)
  privacy            GalleryPrivacy     @default(PRIVATE)
  passwordHash       String?
  coverPhotoId       String?
  coverImageUrl      String?
  allowDownloads     Boolean            @default(true)
  allowSocialSharing Boolean            @default(true)
  watermarkEnabled   Boolean            @default(false)
  watermarkMode      WatermarkMode      @default(TEXT)
  watermarkText      String?
  watermarkImageUrl  String?
  watermarkOpacity   Int                @default(55)
  watermarkSize      Int                @default(140)
  watermarkPosition  WatermarkPosition  @default(BOTTOM_RIGHT)
  storageUsedBytes   BigInt             @default(0)
  viewCount          Int                @default(0)
  settings           Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  publishedAt        DateTime?
  workspace          Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client             Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull)
  coverPhoto         Photo?             @relation("GalleryCover", fields: [coverPhotoId], references: [id], onDelete: SetNull)
  photos             Photo[]            @relation("GalleryPhotos")
  proofSelections    ProofSelection[]
  socialShareEvents  SocialShareEvent[]
  socialDeliveries   SocialDelivery[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, status])
  @@index([workspaceId, privacy])
}

model Photo {
  id               String           @id @default(cuid())
  workspaceId      String
  galleryId        String
  title            String
  caption          String?
  fileName         String
  kind             PhotoKind        @default(IMAGE)
  sortOrder        Int              @default(0)
  width            Int?
  height           Int?
  originalUrl      String
  displayUrl       String?
  thumbnailUrl     String?
  downloadUrl      String?
  sourceUrl        String?
  bytes            BigInt           @default(0)
  displayBytes     BigInt           @default(0)
  thumbnailBytes   BigInt           @default(0)
  isHidden         Boolean          @default(false)
  metadata         Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  gallery          Gallery          @relation("GalleryPhotos", fields: [galleryId], references: [id], onDelete: Cascade)
  coverFor         Gallery[]        @relation("GalleryCover")
  proofSelections  ProofSelection[]
  socialDeliveries SocialDelivery[]

  @@index([workspaceId])
  @@index([galleryId, sortOrder])
  @@index([galleryId, isHidden])
}

model ProofSelection {
  id          String   @id @default(cuid())
  galleryId   String
  photoId     String
  clientName  String?
  clientEmail String?
  isFavorite  Boolean  @default(false)
  comment     String?
  createdAt   DateTime @default(now())
  gallery     Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  photo       Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@index([galleryId, clientEmail])
  @@index([photoId])
}

model StorageUsageEvent {
  id          String           @id @default(cuid())
  workspaceId String
  galleryId   String?
  photoId     String?
  type        StorageEventType
  bytesDelta  BigInt
  pathname    String?
  createdAt   DateTime         @default(now())
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([galleryId])
  @@index([photoId])
}

model StorageDeletionJob {
  id           String                @id @default(cuid())
  workspaceId  String
  galleryId    String?
  photoId      String?
  reference    String
  status       StorageDeletionStatus @default(PENDING)
  attemptCount Int                   @default(0)
  lastError    String?
  completedAt  DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  workspace    Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([workspaceId, status])
}

model OperationalEvent {
  id              String     @id @default(cuid())
  workspaceId     String?
  category        String
  severity        String
  status          String     @default("OPEN")
  source          String
  message         String
  fingerprint     String     @unique
  occurrenceCount Int        @default(1)
  metadata        Json?
  firstOccurredAt DateTime   @default(now())
  lastOccurredAt  DateTime   @default(now())
  lastAlertedAt   DateTime?
  resolvedAt      DateTime?
  workspace       Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([status, severity, lastOccurredAt])
  @@index([category, lastOccurredAt])
  @@index([workspaceId, lastOccurredAt])
}

model ContentPost {
  id             String        @id @default(cuid())
  workspaceId    String
  type           ContentType
  status         ContentStatus @default(DRAFT)
  slug           String
  title          String
  excerpt        String?
  body           String?
  heroImageUrl   String?
  seoTitle       String?
  seoDescription String?
  publishedAt    DateTime?
  scheduledFor   DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, slug])
  @@index([workspaceId, type, status])
  @@index([publishedAt])
}

model GearItem {
  id           String    @id @default(cuid())
  workspaceId  String
  name         String
  slug         String
  category     String
  description  String?
  imageUrl     String?
  amazonUrl    String
  affiliateTag String?
  sortOrder    Int       @default(0)
  isPublished  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, slug])
  @@index([workspaceId, category])
}

model ContactMessage {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String?
  name        String
  email       String
  subject     String?
  message     String
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
}

model SocialShareEvent {
  id          String    @id @default(cuid())
  workspaceId String
  galleryId   String?
  network     String
  shareUrl    String
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  gallery     Gallery?  @relation(fields: [galleryId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([galleryId])
}

model SocialConnection {
  id                    String           @id @default(cuid())
  workspaceId           String
  provider              String
  network               String
  providerAccountId     String
  providerAccountName   String
  accessTokenEncrypted  String
  refreshTokenEncrypted String?
  tokenExpiresAt        DateTime?
  scopes                Json?
  metadata              Json?
  status                String           @default("ACTIVE")
  lastVerifiedAt        DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  workspace             Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deliveries            SocialDelivery[]

  @@unique([workspaceId, network, providerAccountId])
  @@index([workspaceId, status])
  @@index([provider, status])
}

model SocialDelivery {
  id             String           @id @default(cuid())
  workspaceId    String
  connectionId   String
  galleryId      String
  photoId        String
  network        String
  caption        String
  design         Json?
  linkUrl        String?
  imageUrl       String
  scheduledFor   DateTime
  status         String           @default("PENDING")
  attemptCount   Int              @default(0)
  nextAttemptAt  DateTime?
  lastError      String?
  providerPostId String?
  idempotencyKey String           @unique
  publishedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  connection     SocialConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  gallery        Gallery          @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  photo          Photo            @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@index([status, scheduledFor])
  @@index([workspaceId, scheduledFor])
  @@index([connectionId, status])
  @@index([galleryId, scheduledFor])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  userId     String?
  email      String?
  action     String
  targetType String?
  targetId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  eventType  String
  path       String
  title      String?
  referrer   String?
  visitorId  String?
  sessionId  String?
  deviceType String
  galleryId  String?
  durationMs Int?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([eventType, createdAt])
  @@index([path, createdAt])
  @@index([deviceType, createdAt])
  @@index([galleryId, createdAt])
}

model CouponCode {
  id              String        @id @default(cuid())
  code            String        @unique
  name            String
  description     String?
  planSlug        String
  freeDays        Int
  expiresAt       DateTime?
  maxRedemptions  Int?
  redemptionCount Int           @default(0)
  isActive        Boolean       @default(true)
  leadMagnetTitle String?
  leadMagnetNote  String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  trialSignups    TrialSignup[]
  leadCaptures    LeadCapture[]

  @@index([code])
  @@index([expiresAt])
  @@index([isActive])
}

model OneTimeAccessCode {
  id                     String       @id @default(cuid())
  code                   String       @unique
  recipientName          String?
  recipientEmail         String?
  planSlug               String       @default("starter")
  freeDays               Int          @default(14)
  startupSequenceEnabled Boolean      @default(true)
  isActive               Boolean      @default(true)
  assignedAt             DateTime?
  redeemedAt             DateTime?
  invitationSentAt       DateTime?
  invitationEmailStatus  String       @default("NOT_ASSIGNED")
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  trialSignup            TrialSignup?

  @@index([assignedAt, redeemedAt])
  @@index([recipientEmail])
  @@index([isActive])
}

model LeadCapture {
  id           String      @id @default(cuid())
  email        String
  firstName    String
  lastName     String?
  source       String
  status       String      @default("CAPTURED")
  couponCodeId String?
  metadata     Json?
  createdAt    DateTime    @default(now())
  couponCode   CouponCode? @relation(fields: [couponCodeId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([source])
  @@index([couponCodeId])
  @@index([createdAt])
}

model CrmPartner {
  id          String        @id @default(cuid())
  slug        String        @unique
  company     String
  category    String
  stage       String
  score       Int
  valueCents  Int
  website     String
  nextStep    String
  summary     String
  opportunity String
  painPoints  Json
  integration Json
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  contacts    CrmContact[]
  activities  CrmActivity[]
  tasks       CrmTask[]
  meetings    CrmMeeting[]
  notes       CrmNote[]
  outreach    CrmOutreach[]

  @@index([stage, score])
}

model CrmContact {
  id        String     @id @default(cuid())
  partnerId String
  name      String
  role      String
  email     String?
  linkedin  String?
  isPrimary Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  partner   CrmPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, isPrimary])
  @@index([email])
}

model CrmActivity {
  id          String     @id @default(cuid())
  partnerId   String
  type        String
  title       String
  detail      String
  occurredAt  DateTime?
  displayDate String?
  createdAt   DateTime   @default(now())
  partner     CrmPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, createdAt])
}

model CrmTask {
  id          String      @id @default(cuid())
  partnerId   String?
  title       String
  dueAt       DateTime?
  priority    String      @default("NORMAL")
  completedAt DateTime?
  createdById String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  partner     CrmPartner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  createdBy   User        @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([createdById, completedAt, dueAt])
  @@index([partnerId])
}

model CrmMeeting {
  id          String      @id @default(cuid())
  partnerId   String?
  title       String
  startsAt    DateTime
  notes       String?
  createdById String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  partner     CrmPartner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  createdBy   User        @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([createdById, startsAt])
  @@index([partnerId])
}

model CrmNote {
  id          String     @id @default(cuid())
  partnerId   String
  body        String
  createdById String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  partner     CrmPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  createdBy   User       @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([partnerId, createdAt])
  @@index([createdById])
}

model CrmOutreach {
  id          String     @id @default(cuid())
  partnerId   String
  contactId   String?
  subject     String
  body        String
  status      String     @default("DRAFT")
  sentAt      DateTime?
  createdById String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  partner     CrmPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  createdBy   User       @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([partnerId, createdAt])
  @@index([createdById, status])
}

model CrmGoogleConnection {
  id                    String   @id @default(cuid())
  userId                String   @unique
  email                 String
  accessTokenEncrypted  String
  refreshTokenEncrypted String?
  tokenExpiresAt        DateTime
  scopes                Json
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
}
