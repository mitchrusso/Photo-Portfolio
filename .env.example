# =============================================================================
# Scale.gg NextJS Starter App Template - Example Environment Variables
# =============================================================================
# Copy this file to .env and replace values there.
# Every value in this file is fake and safe to commit.
# Never commit .env or any real credential file.
# =============================================================================

# =============================================================================
# REQUIRED
# =============================================================================

# PostgreSQL database connection string.
DATABASE_URL="postgresql://example_user:example_password@localhost:5432/example_app?schema=public"

# Auth.js / NextAuth secret. Generate a real one in .env with:
# openssl rand -base64 32
AUTH_SECRET="example-auth-secret-change-me-minimum-32-characters"

# Local app URL for development.
AUTH_URL="http://localhost:3000"

# Comma-separated emails allowed to access admin operations pages.
ADMIN_EMAILS="owner@example.com"

# Workspace served by legacy /g/:gallery and /embed/:gallery public URLs.
PUBLIC_PORTFOLIO_WORKSPACE_SLUG="your-workspace-slug"

# =============================================================================
# AI SERVICES - OPTIONAL
# =============================================================================

OPENAI_API_KEY="example-openai-api-key"
GEMINI_API_KEY="example-gemini-api-key"
GOOGLE_GENERATIVE_AI_API_KEY="example-google-generative-ai-api-key"

# =============================================================================
# EXTERNAL APIS - OPTIONAL
# =============================================================================

PEXELS_API_KEY="example-pexels-api-key"
FIRECRAWL_API_KEY="example-firecrawl-api-key"
APIFY_API_KEY="example-apify-api-key"

# =============================================================================
# FILE STORAGE
# =============================================================================

# Storage provider for new server-side uploads and import scripts.
# Production uses private Cloudflare R2. Use "vercel-blob" only for a legacy store.
PHOTO_STORAGE_PROVIDER="r2"

# Vercel Blob read-write token. In Vercel, connect a Blob store to the project.
# Locally, pull it with: vercel env pull
BLOB_READ_WRITE_TOKEN=""

# Cloudflare R2 storage. Required when PHOTO_STORAGE_PROVIDER="r2".
# Keep the bucket's r2.dev URL and custom-domain public access disabled.
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET=""
# Optional legacy URL prefix used only while converting old public database URLs
# to private r2:// references. It is never used to deliver new uploads.
CLOUDFLARE_R2_PUBLIC_BASE_URL=""
# Optional override; defaults to https://{accountId}.r2.cloudflarestorage.com
CLOUDFLARE_R2_ENDPOINT=""

# Optional legacy shared secret for older Lightroom/Desktop import clients.
# New subscribers use a workspace-scoped, 90-day token generated in Settings.
PHOTOVIEWPRO_IMPORT_API_KEY=""

# =============================================================================
# PAYMENTS - STRIPE
# =============================================================================

STRIPE_SECRET_KEY="sk_test_example"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_example"
STRIPE_WEBHOOK_SECRET="whsec_example"
# Locks production builds to one mode. Change this only as part of the live cutover.
STRIPE_EXPECTED_MODE="test"
STRIPE_AUTOMATIC_TAX_ENABLED="false"
STRIPE_PRICE_STARTER_MONTHLY="price_starter_monthly"
STRIPE_PRICE_STARTER_YEARLY="price_starter_yearly"
STRIPE_PRICE_GROWTH_MONTHLY="price_growth_monthly"
STRIPE_PRICE_GROWTH_YEARLY="price_growth_yearly"
STRIPE_PRICE_STUDIO_MONTHLY="price_studio_monthly"
STRIPE_PRICE_STUDIO_YEARLY="price_studio_yearly"
STRIPE_PRICE_PREMIER_MONTHLY="price_premier_monthly"
STRIPE_PRICE_PREMIER_YEARLY="price_premier_yearly"
# Legacy fallback names are still accepted for existing deployments.
STRIPE_PRICE_ARCHIVE_MONTHLY=""
STRIPE_PRICE_ARCHIVE_YEARLY=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# =============================================================================
# EMAIL MARKETING - TINYEMAIL
# =============================================================================

TINYEMAIL_API_KEY="te_example"
TINYEMAIL_API_BASE_URL="https://api.tinyemail.com/v1"

# Used by Vercel Cron to run protected background jobs.
CRON_SECRET="replace-with-a-long-random-secret"
# Optional separate secret for /api/email/automations. Defaults to CRON_SECRET.
EMAIL_AUTOMATION_SECRET=""

# Optional transactional lifecycle email provider.
RESEND_API_KEY="re_example"
EMAIL_FROM="PhotoViewPro <hello@example.com>"

# =============================================================================
# AFFILIATE LINKS
# =============================================================================

AMAZON_ASSOCIATE_TAG="example-20"

# =============================================================================
# REAL-TIME SERVICES - OPTIONAL
# =============================================================================

ABLY_API_KEY="example-ably-api-key"
PUSHER_APP_ID="example-pusher-app-id"
PUSHER_KEY="example-pusher-key"
PUSHER_SECRET="example-pusher-secret"
PUSHER_CLUSTER="example-pusher-cluster"
