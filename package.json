{
  "name": "scalegg-nextjs-starter-app-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "prebuild": "node scripts/check-production-config.mjs",
    "build": "next build",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "start": "next start",
    "test": "node --disable-warning=ExperimentalWarning --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test tests/*.test.ts",
    "lint": "eslint",
    "smugmug:public-scan": "node scripts/smugmug-migration.mjs public-scan",
    "smugmug:authorize": "node scripts/smugmug-migration.mjs authorize",
    "smugmug:access-token": "node scripts/smugmug-migration.mjs access-token",
    "smugmug:private-scan": "node scripts/smugmug-migration.mjs private-scan",
    "smugmug:manifest": "node scripts/smugmug-migration.mjs manifest",
    "smugmug:upload-to-blob": "node scripts/smugmug-migration.mjs upload-to-blob",
    "images:generate-display": "node scripts/generate-display-images.mjs",
    "amazon:credentials": "bash scripts/configure-amazon-creators-env.sh",
    "rollout:configure-production": "bash scripts/configure-production-rollout.sh",
    "r2:migrate-vercel-blob": "node scripts/migrate-vercel-blob-to-r2.mjs",
    "r2:migrate-private-references": "node scripts/migrate-r2-private-references.mjs",
    "stripe:verify": "node --env-file-if-exists=.env.local scripts/verify-stripe-cutover.mjs",
    "stripe:verify:live": "node --env-file-if-exists=.env.local scripts/verify-stripe-cutover.mjs --require-live",
    "stripe:verify:production": "bash scripts/verify-production-stripe.sh",
    "subscriber:lifecycle:verify": "node --env-file-if-exists=.env.local --import tsx scripts/verify-subscriber-lifecycle.ts",
    "photoviewpro:watch": "node scripts/photoviewpro-desktop-uploader.mjs"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.10",
    "@ai-sdk/openai": "^3.0.12",
    "@aws-sdk/client-s3": "^3.1080.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@mendable/firecrawl-js": "^4.11.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.90.19",
    "@tiptap/pm": "^3.15.3",
    "@tiptap/react": "^3.15.3",
    "@tiptap/starter-kit": "^3.15.3",
    "@vercel/blob": "^2.5.0",
    "ai": "^6.0.41",
    "amazon-creators-api": "^1.2.2",
    "apify-client": "^2.21.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.30",
    "openai": "^6.16.0",
    "pexels": "^1.4.0",
    "pg": "^8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.71.1",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "postcss": "^8.5.10"
  }
}
